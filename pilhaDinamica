public class Main {
    public static void main(String[] args) {

        PilhaDinamica pilhaDinamica = new PilhaDinamica();

        pilhaDinamica.adicionarElemento("Arroz");
        pilhaDinamica.adicionarElemento("Feijão");
        pilhaDinamica.adicionarElemento("Suco");
        pilhaDinamica.adicionarElemento("Carne");

        pilhaDinamica.exibirElementos();
        pilhaDinamica.buscarElemento("Feijão");
        pilhaDinamica.removerElemento("Feijão");
        pilhaDinamica.exibirElementos();
        
    }


------------------------------------------------------------------------------------------------
    public class PilhaDinamica{
    No inicio;

    public PilhaDinamica() {
        this.inicio = new No(null);
    }

    public boolean estaVazia() {
        return inicio == null;
    }

    public void adicionarElemento(String conteudo) {
        No novo = new No(conteudo);
        novo.setProx(inicio);
        inicio = novo;
        System.out.println("Elemento " + conteudo + " inserido.");

        }

    private boolean existeInicio() {
        if(this.inicio.getConteudo() == null) {
            return false;
        } else {
            return true;
        }
    }

    public void exibirElementos() {
        No aux = inicio;
        while (aux.getProx() != null) {
            System.out.println(aux.getConteudo());
            aux = aux.getProx();
        }
    }

    public void removerElemento(String elemento) {
        if(existeInicio()) {
            if(buscarElemento(elemento)) {
                //removendo primeiro
                if(this.inicio.getConteudo().equals(elemento)) {
                    this.inicio = this.inicio.getProx();
                } else if(this.inicio.getProx() != null) {
                    No aux = this.inicio;
                    do {
                        if(aux.getProx().getConteudo().equals(elemento)) {
                            aux.setProx(aux.getProx().getProx());
                            return;
                        }
                        aux = aux.getProx();
                    } while (aux != null);
                } else {
                    this.inicio.setConteudo(null);
                }
            }

        } else {
            System.out.println("Não existem elementos na lista.");
        }
    }

    public boolean buscarElemento(String elemento) {
        No aux = this.inicio;

        do {
            if(aux.getConteudo().equals(elemento)) {
                System.out.println("Elemento " + elemento + " encontrado.");
                return true;
            }
            aux = aux.getProx();
        } while(aux != null);
        System.out.println("Elemento " + elemento + " não encontrado!");
        return false;
    }
}
